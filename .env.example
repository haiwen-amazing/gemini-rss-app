# Neon PostgreSQL Database Connection
# Get this from your Neon dashboard: https://neon.tech
# Required for Vercel deployment; optional for Cloudflare if D1 is configured
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# Admin Secret for Feed Management
# Set a strong password for accessing the admin panel
ADMIN_SECRET=your-strong-admin-password-here

# Optional: Upstream Proxy (for RSS/Media fetching)
# If deploying in regions with restricted access, set this to a remote HTTP proxy
# Example: http://proxy.example.com:8080
# Leave empty if deploying to Vercel/Cloudflare (usually not needed)
# UPSTREAM_PROXY=

# Optional: Media Proxy Configuration
# Maximum file size for proxied media (in bytes, default: 52428800 = 50MB)
# MEDIA_PROXY_MAX_BYTES=52428800

# Maximum requests per IP per minute for media proxy (default: 120)
# MEDIA_PROXY_MAX_REQUESTS=120

# ─── Cloudflare-specific notes ───
# On Cloudflare Pages, bindings are configured in wrangler.toml, not here:
#   DB            → D1 database binding (preferred over DATABASE_URL)
#   RATE_LIMIT_KV → KV namespace for distributed rate limiting
# Secrets (ADMIN_SECRET, DATABASE_URL) are set via:
#   wrangler pages secret put ADMIN_SECRET
#   wrangler pages secret put DATABASE_URL
